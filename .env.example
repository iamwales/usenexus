# ─────────────────────────────────────────────────────────────
# Nexus — Environment Configuration
# Copy to .env and fill in your values
# Never commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_BASE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Elasticsearch ─────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=

# ── AI / Models ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-min-32-chars
ENCRYPTION_KEY_ID=local
WEBHOOK_SIGNING_SECRET=change-me-too

# ── S3 ────────────────────────────────────────────────────────
S3_BUCKET=nexus-raw-dev
AWS_REGION=us-east-1

# ── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Connectors ────────────────────────────────────────────────
# Create OAuth apps at each provider's developer console
# See docs/connector-setup.md for step-by-step instructions

# Google (Drive + Calendar)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notion
# https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ClickUp
# https://app.clickup.com/settings/apps
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=

# Slack
# https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Atlassian (Confluence)
# https://developer.atlassian.com/console/myapps/
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=

# GitHub App
# https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem

# Linear
# https://linear.app/settings/api
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
